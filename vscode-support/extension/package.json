{
  "name": "serv-vscode",
  "displayName": "Serv Language Support",
  "description": "Full language support for the Serv programming language (.srv files) — diagnostics, autocomplete, hover, go-to-definition.",
  "version": "2.0.0",
  "publisher": "serv-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:serv"
  ],
  "main": "./extension.js",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vyuvaraj/Serv-lang.git"
  },
  "author": {
    "name": "Serv Language Team"
  },
  "keywords": [
    "serv",
    "background services",
    "dsl",
    "syntax highlighting",
    "snippets",
    "lsp"
  ],
  "homepage": "https://github.com/vyuvaraj/Serv-lang",
  "contributes": {
    "languages": [
      {
        "id": "serv",
        "aliases": [
          "Serv",
          "serv"
        ],
        "extensions": [
          ".srv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "serv",
        "scopeName": "source.srv",
        "path": "./syntaxes/serv.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "serv",
        "path": "./snippets/serv.code-snippets"
      }
    ],
    "configuration": {
      "title": "Serv",
      "properties": {
        "serv.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the serv-lsp binary. If empty, looks for 'serv-lsp' in PATH or workspace root."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
